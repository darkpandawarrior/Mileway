<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.mileway.sync</string>
		<string>com.mileway.maintenance</string>
		<string>com.mileway.autodiscard</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.mileway.ios</string>
	<key>CFBundleName</key>
	<string>Mileway</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<!-- Wave-2 §A: FINGERPRINT (YYYY.0M.0W.MILESTONE.commitCount), same computed value as
	     Android's BuildConfig.FINGERPRINT — read via Bundle.main.infoDictionary for an
	     About/build-info screen. $(MILEWAY_FINGERPRINT) is an xcodebuild command-line override
	     (see .github/workflows/github-release.yml's "Archive (unsigned)" step); unset locally it
	     resolves to the literal string below. -->
	<key>MilewayFingerprint</key>
	<string>$(MILEWAY_FINGERPRINT)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.mileway.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>mileway</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSCameraUsageDescription</key>
	<string>Mileway uses the camera to capture odometer readings.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Mileway uses Face ID to protect sensitive account data.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Mileway uses background location to auto-start trip tracking.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Mileway uses your location to track mileage during trips.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Mileway reads photos to attach receipts to expense entries.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
		<string>location</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations~iphone</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
