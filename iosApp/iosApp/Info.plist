<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>com.miletracker.ios</string>
	<key>CFBundleName</key>
	<string>MileTracker</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- DL.3: custom URL scheme (miletracker://). Universal Links use the Associated Domains entitlement. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.miletracker.ios</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>miletracker</string>
			</array>
		</dict>
	</array>
	<!-- Usage strings required by platform features used in this app -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>MileTracker uses your location to track mileage during trips.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>MileTracker uses background location to auto-start trip tracking.</string>
	<key>NSCameraUsageDescription</key>
	<string>MileTracker uses the camera to capture odometer readings.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>MileTracker reads photos to attach receipts to expense entries.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>MileTracker uses Face ID to protect sensitive account data.</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.miletracker.sync</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
		<string>location</string>
		<!-- FCM.4: APNs/FCM background delivery -->
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations~iphone</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
