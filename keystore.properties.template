# Release signing config template.
# Copy to `keystore.properties` (gitignored) and fill in real values, OR set the
# equivalent env vars in CI: RELEASE_STORE_FILE, RELEASE_STORE_PASSWORD,
# RELEASE_KEY_ALIAS, RELEASE_KEY_PASSWORD.
#
# If neither this file nor the env vars are present, `assembleGmsRelease` falls
# back to the debug signing key so the build still produces an installable APK.
storeFile=release.jks
storePassword=changeme
keyAlias=miletracker
keyPassword=changeme
