<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Floating bubble FGS (specialUse subtype declared on the service) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Tracking notification (runtime permission on API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Floating bubble overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Boot receiver -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Wake lock for GPS tracking -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- O.2: Play Services activity recognition (fused into stillness detection) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Haptic feedback (UX.2) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Camera for document scan / odometer capture -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Network state (for offline detection) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MileTrackerApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MileTracker">

        <!-- G2: lets the macrobenchmark shell profile the app for baseline-profile generation.
             Harmless in normal use; the platform also auto-adds this for debuggable builds. -->
        <profileable android:shell="true" />

        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.MileTracker.EdgeToEdge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Custom-scheme deep links: miletracker://home|track[/checkin]|log[/expense]|profile[/settings]|referral?code= -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="miletracker" />
            </intent-filter>
            <!-- App Links: https://miletracker.example.com/… (placeholder host; verified via assetlinks.json) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="miletracker.example.com" />
            </intent-filter>
        </activity>

        <!-- Phase 9: TrackMilesActivity registered here -->
        <!-- Phase 10: LoggingActivity registered here -->
        <!-- Phase 5: MediaActivity registered here -->

        <!-- FileProvider for sharing exported track files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
