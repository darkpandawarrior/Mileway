<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Floating bubble FGS (specialUse subtype declared on the service) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Tracking notification (runtime permission on API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Floating bubble overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Boot receiver -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Wake lock for GPS tracking -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- O.2: Play Services activity recognition (fused into stillness detection) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Haptic feedback (UX.2) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Camera for document scan / odometer capture -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Network state (for offline detection) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MilewayApplication"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mileway">

        <!-- G2: lets the macrobenchmark shell profile the app for baseline-profile generation.
             Harmless in normal use; the platform also auto-adds this for debuggable builds. -->
        <profileable android:shell="true" />

        <!-- P7.5: AppFunctions — describes this app's agentic capabilities to the system indexer. -->
        <property
            android:name="android.app.appfunctions.app_metadata"
            android:resource="@xml/app_metadata" />

        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Mileway.EdgeToEdge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Custom-scheme deep links: mileway://home|track[/checkin]|log[/expense]|profile[/settings]|referral?code= -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="mileway" />
            </intent-filter>
            <!-- App Links: https://mileway.example.com/… (placeholder host; verified via assetlinks.json) -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="mileway.example.com" />
            </intent-filter>

            <!-- P7.2: static App Shortcuts (long-press launcher) + App Actions capability. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Phase 9: TrackMilesActivity registered here -->
        <!-- Phase 10: LoggingActivity registered here -->
        <!-- Phase 5: MediaActivity registered here -->

        <!-- DL.5: tracking control-op deep links / App Intents — mileway://track/{start,stop,pause,discard}.
             Separate from LauncherActivity so a partner/Shortcuts caller gets a result back
             (setResult) without the full app shell ever appearing (except the confirmation sheet
             for Stop/Discard). `checkin` deliberately excluded — it's a nav route/guided flow, not
             a headless op, and already resolves through LauncherActivity's existing filter below.
             noHistory: this Activity never belongs on the back stack. -->
        <activity
            android:name=".DeepLinkActionActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.Mileway.EdgeToEdge">
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="mileway" android:host="track" android:pathPattern="/start" />
                <data android:scheme="mileway" android:host="track" android:pathPattern="/stop" />
                <data android:scheme="mileway" android:host="track" android:pathPattern="/pause" />
                <data android:scheme="mileway" android:host="track" android:pathPattern="/discard" />
            </intent-filter>
        </activity>

        <!-- P7.3: Quick Settings tile — start/stop tracking without opening the app UI. -->
        <service
            android:name=".qs.TrackingTileService"
            android:exported="true"
            android:icon="@drawable/ic_logo_mark"
            android:label="@string/qs_tile_tracking_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- FileProvider for sharing exported track files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
