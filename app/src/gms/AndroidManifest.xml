<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Provide your Google Maps API key here, or via local.properties:
         MAPS_API_KEY=AIza...  (never commit a real key to VCS) -->
    <application>
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- V15 FCM.2: Firebase Cloud Messaging service (gms flavor only). -->
        <service
            android:name="com.mileway.platform.gms.MilewayFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="mileway_general" />

        <!-- V15 CF.4: Crashlytics collection OFF by default (privacy); CrashReporter.setEnabled flips it. -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false" />

        <!-- P2.10: watch->phone start/stop-tracking command (Wear OS Data Layer MessageClient). -->
        <service
            android:name="com.mileway.platform.gms.WearTrackingCommandService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/mileway/track-command" />
            </intent-filter>
        </service>

        <!-- P2.10: declares the `mileway_phone_track` capability (see res/values/wear.xml) so
             wear/src/gms's WearTrackingCommandSender can resolve this phone's node id. -->
        <meta-data
            android:name="com.google.android.wearable.capability"
            android:resource="@array/android_wear_capabilities" />
    </application>
</manifest>
