default_platform(:android)

platform :android do

  desc "Run unit tests"
  lane :test do
    gradle(task: "testDebugUnitTest")
  end

  desc "Build a debug APK"
  lane :build do
    gradle(task: "assembleDebug")
  end

  desc "CI: run tests, then build"
  lane :ci do
    test
    build
  end

  desc "Capture Roborazzi baseline screenshots (JVM — no device needed)"
  lane :screenshots do
    # Roborazzi captures images as a side effect of the test run.
    # Output path is configured in roborazzi.properties.
    gradle(
      task: "testDebugUnitTest",
      flags: "--tests com.miletracker.ScreenshotTests --rerun-tasks"
    )
  end

  desc "Verify screenshots against recorded baselines (re-run and diff)"
  lane :verify_screenshots do
    gradle(
      task: "testDebugUnitTest",
      flags: "--tests com.miletracker.ScreenshotTests"
    )
  end

  desc "Build a release AAB (requires signing config)"
  lane :release_bundle do
    gradle(
      task: "bundle",
      build_type: "Release"
    )
  end

end
