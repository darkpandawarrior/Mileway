root = true

# Generated code from KSP/Room/KotlinPoet — never lint
[**/build/**/*.kt]
ktlint = disabled

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
max_line_length = 160
# Composable functions use PascalCase by convention — disable the naming rule globally.
ktlint_standard_function-naming = disabled

[*.kts]
max_line_length = 160

[*.{yml,yaml}]
indent_size = 2
